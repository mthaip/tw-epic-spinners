{
  "name": "tw-epic-spinners",
  "version": "1.2.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "description": "20 pure-CSS loading spinners as a Tailwind CSS plugin (v3 & v4). Zero JS, framework-agnostic — works with Vue, React, Svelte, Astro, Next.js, Nuxt, or plain HTML. A Tailwind port of Epic Spinners by EpicMax.",
  "author": "mthaip <fanmt.fmt@gmail.com>",
  "homepage": "https://tw-epic-spinners.mthaip.com",
  "url": "https://github.com/mthaip/tw-epic-spinners",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mthaip/tw-epic-spinners.git"
  },
  "keywords": [
    "tailwindcss",
    "tailwindcss-plugin",
    "tailwind-plugin",
    "tailwind",
    "tailwindcss-v4",
    "tailwindcss-v3",
    "spinner",
    "spinners",
    "loading-spinner",
    "loader",
    "loading",
    "loading-indicator",
    "css-spinner",
    "css-animation",
    "pure-css",
    "no-js",
    "vue",
    "react",
    "svelte",
    "astro",
    "nextjs",
    "nuxt",
    "epic-spinners",
    "tw-epic-spinners",
    "ui",
    "frontend",
    "plugin"
  ],
  "scripts": {
    "lint": "eslint --ignore-path .eslintignore --ext .js,.ts",
    "npm:build:readme": "node scripts/build-readme.mjs",
    "npm:build": "npm run npm:build:readme && rm -rf dist && vite build -c ./vite.config.ts",
    "prepare": "node scripts/build-readme.mjs",
    "prepublishOnly": "node scripts/build-readme.mjs"
  },
  "peerDependencies": {
    "tailwindcss": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "10.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  },
  "packageManager": "yarn@1.22.22"
}
